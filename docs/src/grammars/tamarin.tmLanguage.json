{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tamarin",
  "scopeName": "source.spthy",
  "fileTypes": ["spthy"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#theory" },
    { "include": "#strings" },
    { "include": "#operators" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#facts" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.spthy",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.spthy" }
          },
          "patterns": [
            {
              "name": "keyword.todo.spthy",
              "match": "\\b(TODO|FIXME|XXX|NOTE|HACK|BUG)\\b"
            }
          ]
        },
        {
          "name": "comment.line.double-slash.spthy",
          "match": "//.*$",
          "captures": {
            "0": { "name": "punctuation.definition.comment.spthy" }
          }
        },
        {
          "name": "comment.block.formal.spthy",
          "begin": "\\{\\*",
          "end": "\\*\\}",
          "captures": {
            "0": { "name": "punctuation.definition.comment.spthy" }
          }
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.ifdef.spthy",
          "match": "^\\s*(#ifdef|#else|#endif|#define|#include)\\b",
          "captures": {
            "1": { "name": "keyword.control.directive.spthy" }
          }
        }
      ]
    },
    "theory": {
      "patterns": [
        {
          "name": "meta.theory.spthy",
          "match": "\\b(theory|begin|end)\\b",
          "captures": {
            "1": { "name": "keyword.control.spthy" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.spthy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.spthy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.spthy",
          "match": "'[^']*'"
        },
        {
          "name": "string.quoted.fresh-name.spthy",
          "match": "~'[^']*'"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.spthy",
          "match": "(-->|--\\[|\\]->|->|<-)"
        },
        {
          "name": "keyword.operator.logical.spthy",
          "match": "(==>|<=>|⇒|⇔|∧|∨|¬)"
        },
        {
          "name": "keyword.operator.comparison.spthy",
          "match": "(<<|⊏|<:|:>|>\\+>|>->)"
        },
        {
          "name": "keyword.operator.temporal.spthy",
          "match": "@"
        },
        {
          "name": "keyword.operator.action.spthy",
          "match": "(--|\\|)"
        },
        {
          "name": "keyword.operator.arithmetic.spthy",
          "match": "(\\^|\\*|\\+\\+|%\\+|XOR|⊕)"
        },
        {
          "name": "keyword.operator.replication.spthy",
          "match": "!"
        },
        {
          "name": "keyword.operator.comparison.spthy",
          "match": "="
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.spthy",
          "match": "\\b(rule|lemma|restriction|axiom|equations|functions|builtins|predicates?|predicate|macros|options|heuristic|tactic|process|export|test|section|subsection|text)\\b"
        },
        {
          "name": "keyword.control.lemma.spthy",
          "match": "\\b(all-traces|exists-trace|diffLemma|equivLemma|diffEquivLemma)\\b"
        },
        {
          "name": "keyword.control.proof.spthy",
          "match": "\\b(SOLVED|MIRRORED|ATTACK|sorry|simplify|solve|contradiction|induction|rule-equivalence|backward-search|by|case|next|qed|step)\\b"
        },
        {
          "name": "keyword.control.process.spthy",
          "match": "\\b(new|in|out|if|then|else|let|event|insert|delete|lookup|as|lock|unlock)\\b"
        },
        {
          "name": "keyword.control.modifiers.spthy",
          "match": "\\b(modulo|variants|left|right|account|accounts|for|parties|otherwise)\\b"
        },
        {
          "name": "keyword.other.quantifier.spthy",
          "match": "\\b(All|Ex|∀|∃)\\b"
        },
        {
          "name": "constant.language.boolean.spthy",
          "match": "\\b(T|F|⊤|⊥)\\b"
        },
        {
          "name": "keyword.other.attribute.spthy",
          "match": "\\b(sources|reuse|use_induction|hide_lemma|private|destructor|no-decomp|no_precomp)\\b"
        },
        {
          "name": "keyword.other.heuristic.spthy",
          "match": "\\b(presort|prio|deprio|smallest|id|regex|isFactName|isInFactTerms|dhreNoise|defaultNoise|reasonableNoncesNoise|nonAbsurdGoal)\\b"
        },
        {
          "name": "keyword.other.output.spthy",
          "match": "\\b(spthy|spthytyped|msr|proverif|deepsec)\\b"
        },
        {
          "name": "storage.modifier.spthy",
          "match": "\\b(pub|fresh|msg|node|nat|temporal|ANY)\\b"
        },
        {
          "name": "keyword.control.sapic.spthy",
          "match": "\\b(_restrict|last)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.type.builtin.spthy",
          "match": "\\b(diffie-hellman|hashing|symmetric-encryption|asymmetric-encryption|signing|bilinear-pairing|xor|multiset|natural-numbers|revealing-signing|locations-report|reliable-channel|dest-pairing|dest-signing|dest-symmetric-encryption|dest-asymmetric-encryption)\\b"
        },
        {
          "name": "support.type.option.spthy",
          "match": "\\b(translation-state-optimisation|translation-progress|translation-asynchronous-channels|translation-compress-events|translation-allow-pattern-lookups)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.crypto.spthy",
          "match": "\\b(aenc|adec|senc|sdec|sign|verify|h|sk|pk|fr|pb|lts|fst|snd|pair|true|getMessage|revealSign|revealVerify)\\b"
        },
        {
          "name": "entity.name.function.spthy",
          "match": "\\b([a-z][A-Za-z0-9_]*)(?=\\s*\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.public.spthy",
          "match": "\\$[A-Za-z][A-Za-z0-9_]*(?:\\.[0-9]+)?"
        },
        {
          "name": "variable.other.fresh.spthy",
          "match": "~[A-Za-z][A-Za-z0-9_]*(?:\\.[0-9]+)?"
        },
        {
          "name": "variable.other.temporal.spthy",
          "match": "#[A-Za-z][A-Za-z0-9_]*(?:\\.[0-9]+)?"
        },
        {
          "name": "variable.other.natural.spthy",
          "match": "%[A-Za-z][A-Za-z0-9_]*(?:\\.[0-9]+)?"
        },
        {
          "name": "variable.other.message.spthy",
          "match": "\\b[a-z][A-Za-z0-9_]*(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "facts": {
      "patterns": [
        {
          "comment": "Fresh value generation - special built-in fact",
          "name": "markup.inserted.spthy",
          "match": "\\b(Fr)(?=\\s*\\()"
        },
        {
          "comment": "Network input from adversary - special built-in fact",
          "name": "markup.deleted.spthy",
          "match": "\\b(In)(?=\\s*\\()"
        },
        {
          "comment": "Network output to adversary - special built-in fact",
          "name": "string.special.spthy",
          "match": "\\b(Out)(?=\\s*\\()"
        },
        {
          "comment": "Adversary knowledge facts",
          "name": "markup.deleted.spthy",
          "match": "\\b(K|KU|KD)(?=\\s*\\()"
        },
        {
          "name": "entity.name.type.fact.persistent.spthy",
          "match": "![A-Z][A-Za-z0-9_]*"
        },
        {
          "name": "entity.name.type.fact.spthy",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.spthy",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.numeric.subscript.spthy",
          "match": "[₀₁₂₃₄₅₆₇₈₉]+"
        },
        {
          "name": "constant.other.hexcolor.spthy",
          "match": "#[0-9a-fA-F]{1,6}\\b"
        }
      ]
    }
  }
}
