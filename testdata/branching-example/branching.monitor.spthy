theory BranchingExample

begin

rule Branch1[no-decomp, role="*", trigger=[<choose(x), <>>]]:
  [ ] --> [ !A(x) ]

rule Branch2[no-decomp, role="*", trigger=[<choose(x), <>>]]:
  [ ] --> [ !B(x) ]

rule ExpectA[no-decomp, role="*", trigger=[<recvA(x), <>>]]:
  [ !A(x) ] --> [ ]

rule ExpectB[no-decomp, role="*", trigger=[<recvB(x), <>>]]:
  [ !B(x) ] --> [ ]

end
