theory LiveMultiError

begin

rule BranchA[no-decomp, role="*", trigger=[<choose(x), <>>]]:
  [ ] --> [ !A(x) ]

rule BranchB[no-decomp, role="*", trigger=[<choose(x), <>>]]:
  [ ] --> [ !B(x) ]

rule BranchC[no-decomp, role="*", trigger=[<choose(x), <>>]]:
  [ ] --> [ !C(x) ]

rule RecvA[no-decomp, role="*", trigger=[<recv(c, m), <>>]]:
  [ !A(x) ] --> [ ]

rule RecvB[no-decomp, role="*", trigger=[<recv(c, m), <>>]]:
  [ !B(x) ] --> [ ]

rule RecvC[no-decomp, role="*", trigger=[<recv(c, m), <>>]]:
  [ !C(x) ] --> [ ]

end
