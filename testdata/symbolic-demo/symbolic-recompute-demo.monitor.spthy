theory SymbolicRecomputeDemo

begin

rule Recv[no-decomp, role="*", trigger=[<recv(c), m>]]:
  [ ] --> [ In(m) ]

rule Hash[no-decomp, role="*", trigger=[<hash(m), <>>]]:
  [ ] --> [ ]

rule Hmac[no-decomp, role="*", trigger=[<hmac(k, m), <>>]]:
  [ ] --> [ ]

rule UseHash[no-decomp, role="*", trigger=[<use_hash(v), <>>]]:
  [ ] --> [ ]

rule UseMac[no-decomp, role="*", trigger=[<use_mac(v), <>>]]:
  [ ] --> [ ]

rule Send[no-decomp, role="*", trigger=[<send(v), <>>]]:
  [ ] --> [ ]

end
